generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified Boolean @default(false)
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  yearlyGoals      YearlyGoal[]
  habits           Habit[]
  timeBlocks       TimeBlock[]
  analytics        AnalyticsSnapshot[]
  focusSessions    FocusSession[]
  journalEntries   JournalEntry[]
  messagesSent     ChatMessage[] @relation("MessagesSent")
  messagesReceived ChatMessage[] @relation("MessagesReceived")

  sentInvites      AccountabilityInvite[] @relation("SentInvites")
  receivedInvites  AccountabilityInvite[] @relation("ReceivedInvites")
  partnersFrom     AccountabilityPartner[] @relation("PartnerFrom")
  partnersTo       AccountabilityPartner[] @relation("PartnerTo")

  accounts      Account[]
  sessions      Session[]
  challenges    Challenge[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  accountId         String
  providerId        String
  providerType      String?
  password          String?
  accessToken       String?
  refreshToken      String?
  accessTokenExpiresAt DateTime?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([providerId, accountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ip           String?
  userAgent    String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model YearlyGoal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  deadline    DateTime?
  notes       String?
  status      String   @default("ACTIVE")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  monthlyGoals MonthlyGoal[]
}

model MonthlyGoal {
  id             String     @id @default(cuid())
  yearlyGoalId    String
  yearlyGoal     YearlyGoal @relation(fields: [yearlyGoalId], references: [id], onDelete: Cascade)

  title          String
  description    String?
  deadline       DateTime?
  notes          String?
  status         String     @default("ACTIVE")

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  weeklyPlans    WeeklyPlan[]
}

model WeeklyPlan {
  id           String      @id @default(cuid())
  monthlyGoalId String
  monthlyGoal  MonthlyGoal @relation(fields: [monthlyGoalId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime
  notes        String?
  status       String      @default("ACTIVE")

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tasks        Task[]
}

model Task {
  id            String      @id @default(cuid())
  weeklyPlanId  String
  weeklyPlan    WeeklyPlan  @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  priority      String      @default("MEDIUM")
  status        String      @default("PENDING")
  effortValue   Int         @default(1)

  deadline      DateTime?
  reminder      DateTime?
  notes         String?
  category      String      @default("OTHER")

  isRecurring   Boolean     @default(false)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  timeBlocks    TimeBlock[]
}

model Habit {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String     @default("PERSONAL")
  targetDays  String     @default("[]")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  logs        HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  date      DateTime
  status    String   @default("COMPLETED")

  createdAt DateTime @default(now())
}

model TimeBlock {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  category    String   @default("OTHER")

  startTime   DateTime
  endTime     DateTime
  isAllDay    Boolean  @default(false)

  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalyticsSnapshot {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  period             String
  startDate          DateTime
  endDate            DateTime

  taskCompletionRate Float
  habitConsistency   Float
  timeAllocation     String   @default("{}")
  productivityScore  Float

  createdAt          DateTime @default(now())
}

model TaskCompletionLog {
  id                       String   @id @default(cuid())
  userId                   String
  taskId                   String
   
  scheduledTime            DateTime?
  actualCompletionTime     DateTime
  completionDelayMinutes    Float?
  completionHour           Int?
  completionDayOfWeek      Int?
  
  createdAt                DateTime @default(now())

  @@index([userId])
  @@index([taskId])
}

model FocusSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  duration    Int      @default(25)
  type        String   @default("work")
  taskId      String?
  taskTitle   String?

  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([userId])
}

model AccountabilityInvite {
  id          String    @id @default(cuid())
  code        String    @unique
  message     String?
  
  fromUserId  String
  fromUser    User      @relation("SentInvites", fields: [fromUserId], references: [id], onDelete: Cascade)
  
  toUserId    String?
  toUser      User?     @relation("ReceivedInvites", fields: [toUserId], references: [id], onDelete: SetNull)
  
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  @@index([code])
  @@index([fromUserId])
  @@index([toUserId])
}

model AccountabilityPartner {
  id          String    @id @default(cuid())
  
  fromUserId  String
  fromUser    User      @relation("PartnerFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  
  toUserId    String
  toUser      User      @relation("PartnerTo", fields: [toUserId], references: [id], onDelete: Cascade)
  
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
}

model JournalEntry {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String?
  content     String

  mood        Int       @default(3)
  tags        String    @default("[]")

  promptAccomplishments  String?
  promptWentWell         String?
  promptDidntGoWell      String?
  promptImproveTomorrow   String?

  completedTaskIds       String    @default("[]")
  missedTaskIds          String    @default("[]")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model ChatMessage {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId  String
  receiver    User      @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  content     String

  read        Boolean   @default(false)

  createdAt   DateTime  @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Challenge {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  category    String    @default("GENERAL")
  status      String    @default("ACTIVE")
  priority    String    @default("MEDIUM")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  responsePlan ResponsePlan?
}

model ResponsePlan {
  id            String    @id @default(cuid())
  challengeId   String    @unique
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  steps         String    @default("[]")
  deadline      DateTime?
  status        String    @default("PENDING")
  progress      Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  @@index([challengeId])
}
